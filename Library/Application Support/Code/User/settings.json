
{
    "workbench.startupEditor": "none",
    //======FONT CONFIG=====
    "editor.fontWeight": "400",
    "editor.lineHeight": 18,
    "editor.fontFamily": "JetBrainsMono Nerd Font Mono",
    "editor.fontLigatures": false,
    "editor.fontSize": 13.5,
    "terminal.integrated.fontWeight": "400",
    "terminal.integrated.lineHeight": 1,
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
    "terminal.integrated.fontSize": 13.5,
    "terminal.integrated.gpuAcceleration": "on",
    //======ZEN MODE=====
    "editor.minimap.enabled": false,
    "zenMode.fullScreen": false, // Disabilita lo schermo intero
    "zenMode.hideStatusBar": true, // Nasconde la barra blu in basso
    "zenMode.hideLineNumbers": false, // Mantieni i numeri se ti servono per le Vim motions
    "zenMode.centerLayout": false, // Centra il codice al centro dello schermo (fondamentale!)
    "zenMode.restore": true, // Riapre in Zen Mode se hai chiuso così
    "zenMode.showTabs": "none",
    "editor.cursorSmoothCaretAnimation": "on",
    "workbench.colorCustomizations": {
        "editorGroup.border": "#00000000",
        "editorCenteredLayout.background": "#1a1b26", // Metti qui il colore del tuo tema
        "editorLineNumber.foreground": "#5c6773", // Colore numeri normali
        "editorLineNumber.activeForeground": "#ffcc66", // Colore della riga corrente (stile Ayu)
    },
    //=======VIM CONFIGURATION=======
    "vim.vimrc.enable": true,
    "vim.vimrc.path": "~/.ideavimrc",
    "vim.useSystemClipboard": true,
    "vim.hlsearch": true,
    "keyboard.dispatch": "keyCode",
    "editor.tabSize": 4,
    "editor.detectIndentation": false,
    "editor.insertSpaces": true,
    "workbench.editor.empty.hint": "hidden",
    "terminal.integrated.initialHint": false,
    //========AUTOSAVE=========
    "files.autoSave": "afterDelay",
    //====== PYTHON & INLAY HINTS CONFIG =====
    "python.analysis.inlayHints.variableTypes": true,
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.callArgumentNames": "all",
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "vim.handleKeys": {
        "<C-f>": false,
        "<C-c>": false,
        "<C-v>": false,
        "<C-a>": false,
        "<C-z>": false,
        "<C-h>": false,
    },
    
    "github.copilot.editor.enableAutoCompletions": true,
    "github.copilot.nextEditSuggestions.eagerness": "medium",
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },

    //====== OTTIMIZZAZIONI PRESTAZIONI E VELOCITÀ INTELLISENSE =====
    "editor.suggestDelay": 0, // Rimuove il ritardo della comparsa del menu
    "editor.quickSuggestionsDelay": 0, // Calcolo istantaneo dei suggerimenti mentre digiti
    "editor.quickSuggestions": {
        "other": true,
        "comments": false, // Non spreca CPU nei commenti
        "strings": false   // Non spreca CPU nelle stringhe di testo
    },
    "editor.formatOnType": false, // Disattivato: formattare ad ogni singola lettera bloccava l'input su Linux tunnel
    "editor.inlayHints.enabled": "offUnlessPressed", // Mostra i tipi solo se premi Ctrl+Alt (non rallenta la digitazione)
    "python.analysis.typeCheckingMode": "basic", // Pylance non esegue più il controllo continuo dei tipi in background
    "python.analysis.diagnosticMode": "workspace", // Analizza solo il file aperto, ignora il resto del sistema
    "C_Cpp.workspaceParsingPriority": "low", // Impedisce al server C++ di rubare core della CPU durante la digitazione
    "C_Cpp.enhancedColorization": false,
    "claudeCode.preferredLocation": "panel",
    "terminal.integrated.enableMultiLinePasteWarning": "never" // Velocizza il rendering grafico dei suggerimenti C++
}
